{{- if not .Values.secret.existingSecret }}
apiVersion: v1
kind: Secret
metadata:
  name: {{ include "pauseai-es-presentaciones.fullname" . }}-secret
  labels:
    {{- include "pauseai-es-presentaciones.labels" . | nindent 4 }}
type: Opaque
stringData:
  SLIDEV_PASSWORD: {{ .Values.secret.slidevPassword | quote }}
{{- end }}
